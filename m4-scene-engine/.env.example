# ============================================================
# M4 - 场景引擎 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# M4 业务场景引擎配置示例
# 复制为 .env 并修改配置

# 服务配置
M4_PORT=8004
M4_ENV=development

# 场景配置
M4_DEFAULT_SCENE=work
M4_AUTO_SWITCH=true
M4_SWITCH_THRESHOLD=0.7
M4_KEYWORD_THRESHOLD=0.7

# LLM 增强识别（可选）
M4_ENABLE_LLM=false
M4_LLM_BASE_URL=
M4_LLM_MODEL=

# 数据配置
M4_MAX_HISTORY=100
M4_DATA_PATH=./data

# M8 对接
M4_ADMIN_TOKEN=yunxi-m4-admin-token-2026
