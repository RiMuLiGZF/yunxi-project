# ============================================================
# M12 - 安全盾 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# 服务配置
M12_HOST=0.0.0.0
M12_PORT=8012
M12_ENV=development
M12_LOG_LEVEL=info

# 调试模式（生产环境必须设为 false）
M12_DEBUG=false

# JWT 签名密钥（必须设置，严禁使用默认值）
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(64))"
M12_JWT_SECRET=

# 是否强制要求安全密钥（生产环境必须保持 true）
M12_REQUIRE_SECURE_SECRET=true

# 管理员账户（用于登录认证）
M12_ADMIN_USERNAME=admin
# 管理员密码哈希（bcrypt 格式）
M12_ADMIN_PASSWORD_HASH=

# CORS 配置
M12_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# WAF 配置
M12_WAF_ENABLED=true

# 速率限制
M12_RATE_LIMIT_ENABLED=true
M12_DEFAULT_RATE_PER_MINUTE=60

# 数据库路径
M12_DB_PATH=./data/m12.db

# 审计日志保留天数
M12_AUDIT_RETENTION_DAYS=90
