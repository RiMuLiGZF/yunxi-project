# ============================================================
# 六、模块间调用配置
# ============================================================

# 各模块的 base URL（内部调用用，Docker 部署时修改为容器名）
M1_BASE_URL=http://localhost:8001
M2_BASE_URL=http://localhost:8002
M3_BASE_URL=http://localhost:8003
M4_BASE_URL=http://localhost:8004
M5_BASE_URL=http://localhost:8005
M6_BASE_URL=http://localhost:8006
M7_BASE_URL=http://localhost:8007
M8_BASE_URL=http://localhost:8008
M9_BASE_URL=http://localhost:8009
M10_BASE_URL=http://localhost:8010
M11_BASE_URL=http://localhost:8011
M12_BASE_URL=http://localhost:8012

# ============================================================
# 七、安全配置
# ============================================================

# WAF Web 应用防火墙配置
WAF_ENABLED=true
# 生产环境建议先使用 monitor 模式观察，确认无误后切换到 block
WAF_MODE=monitor
# 启用的规则类型，逗号分隔，留空表示启用全部
# 可选值: sql_injection,xss,command_injection,path_traversal,csrf
WAF_RULE_TYPES=sql_injection,xss,command_injection,path_traversal
# 排除的路径（逗号分隔）
WAF_EXCLUDE_PATHS=/health,/metrics
# 请求体检测大小限制（KB）
WAF_BODY_LIMIT_KB=64

# CORS 配置（生产环境必须限制为具体域名）
# 多个域名用逗号分隔
CORS_ORIGINS=https://yunxi.example.com,https://admin.example.com

# 请求超时配置
REQUEST_TIMEOUT=30
MAX_RETRY=3
RETRY_DELAY=1

# ============================================================
# 八、运维监控配置
# ============================================================

# 是否启用 Prometheus 指标采集
METRICS_ENABLED=true
METRICS_PORT=9090

# 健康检查配置
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5

# 告警配置（可选，接入告警系统时使用）
ALERT_WEBHOOK_URL=
ALERT_LEVEL=warning

# ============================================================
# 九、备份配置
# ============================================================

# 自动备份开关
BACKUP_ENABLED=true
# 备份目录
BACKUP_DIR=/var/backup/yunxi
# Windows 环境使用：BACKUP_DIR=D:\yunxi\backup
# 备份保留天数
BACKUP_RETENTION_DAYS=30
# 备份时间（cron 格式，每日凌晨 2 点）
BACKUP_SCHEDULE=0 2 * * *
# 是否压缩备份
BACKUP_COMPRESS=true
# 是否加密备份
BACKUP_ENCRYPT=false
BACKUP_ENCRYPT_KEY=CHANGEME_BACKUP_ENCRYPT_KEY
