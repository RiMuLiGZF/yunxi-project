M3_NAME=m3-sync
M3_PORT=8003
M3_HOST=0.0.0.0
# ⚠️ 生产环境必须修改：管理员 Token
M3_ADMIN_TOKEN=CHANGEME_M3_ADMIN_TOKEN_32CHARS
# ⚠️ 生产环境必须修改：加密密钥
M3_ENCRYPTION_KEY=CHANGEME_M3_ENCRYPTION_KEY_64HEX
M3_DATABASE_PATH=${YUNXI_DATA_DIR}/m3.db
M3_LOG_LEVEL=${YUNXI_LOG_LEVEL}

# ---------- M4 场景引擎 ----------
M4_NAME=m4-scenes
M4_PORT=8004
M4_HOST=0.0.0.0
# ⚠️ 生产环境必须修改：管理员 Token
M4_ADMIN_TOKEN=CHANGEME_M4_ADMIN_TOKEN_32CHARS
# ⚠️ 生产环境必须修改：加密密钥
