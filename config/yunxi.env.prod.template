# ============================================================
# 云汐系统 - 生产环境配置模板
# 所有模块的配置集中在这里，模块启动时自动加载
#
# ⚠️  安全提示（生产环境必读）：
# 1. 复制本文件为 yunxi.env.prod 后再修改
# 2. 所有 CHANGEME_ 开头的配置项必须替换为强随机值
# 3. 推荐使用以下命令生成密钥：
#    - PowerShell: -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Maximum 256) })
#    - Linux/Mac: openssl rand -hex 32
# 4. yunxi.env.prod 已在 .gitignore 中，不会被提交到仓库
# 5. 密钥长度建议：JWT_SECRET >= 32字节，API_TOKEN >= 16字节
# 6. 生产环境务必设置文件权限，仅允许服务账户读取
# ============================================================

# ============================================================
# 一、全局基础配置
# ============================================================

# 运行环境标识（必须设为 production）
YUNXI_ENV=production

# 系统版本号（部署时自动更新）
YUNXI_VERSION=1.0.0

# 日志级别（生产环境建议 info 或 warning）
# 可选值: debug, info, warning, error, critical
YUNXI_LOG_LEVEL=info

# 日志目录（生产环境建议统一存放，便于日志收集）
# 绝对路径推荐，避免相对路径带来的问题
YUNXI_LOG_DIR=/var/log/yunxi
# Windows 环境使用：YUNXI_LOG_DIR=C:\yunxi\logs

# 数据目录（生产环境建议使用独立磁盘分区）
YUNXI_DATA_DIR=/var/lib/yunxi
# Windows 环境使用：YUNXI_DATA_DIR=D:\yunxi\data

# 服务监听地址（生产环境建议绑定内网地址）
# 0.0.0.0 表示监听所有网卡，生产环境建议绑定具体内网IP
YUNXI_BIND_HOST=0.0.0.0

# ============================================================
# 二、大模型配置
# ============================================================

# LLM 提供商: deepseek / openai / ollama / azure
LLM_PROVIDER=ollama

# API 密钥（生产环境务必填写真实密钥）
LLM_API_KEY=CHANGEME_LLM_API_KEY

# API 基础地址
LLM_BASE_URL=http://localhost:11434/v1

# 默认模型
LLM_MODEL=qwen2.5:7b

# 请求超时时间（秒）
LLM_TIMEOUT=60

# 嵌入模型配置
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# 本地 Ollama 配置（LLM_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=5m
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_AVAILABLE_MODELS=qwen2.5:7b,qwen2.5:14b,qwen2.5:32b

# ============================================================
# 三、数据库与缓存配置
# ============================================================

# Redis 配置（生产环境建议设置密码）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGEME_REDIS_PASSWORD
REDIS_DB=0
# 连接池配置
REDIS_POOL_SIZE=50
REDIS_MAX_OVERFLOW=20

# 向量数据库（ChromaDB）配置
CHROMADB_HOST=localhost
CHROMADB_PORT=8100
CHROMADB_AUTH_TOKEN=CHANGEME_CHROMADB_TOKEN

# 数据库通用配置
# SQLite 数据库文件存放目录（生产环境建议放在独立数据盘）
DB_DATA_DIR=${YUNXI_DATA_DIR}/database
# Windows 环境使用：DB_DATA_DIR=${YUNXI_DATA_DIR}\database

# ============================================================
# 四、API Gateway 配置
# ============================================================

# 网关端口
GATEWAY_PORT=8080

# ⚠️ 生产环境必须修改：JWT 签名密钥（至少32字节）
GATEWAY_JWT_SECRET=CHANGEME_GATEWAY_JWT_SECRET_64CHARS
GATEWAY_JWT_ALGORITHM=HS256
GATEWAY_JWT_ISSUER=yunxi
GATEWAY_JWT_EXPIRE_HOURS=24

# ⚠️ 生产环境必须配置：服务间调用 API Key（多个用逗号分隔）
GATEWAY_API_KEY_1=CHANGEME_GATEWAY_API_KEY_1
GATEWAY_API_KEY_2=CHANGEME_GATEWAY_API_KEY_2

# 限流配置（生产环境按需调整）
GATEWAY_RATE_LIMIT_TOTAL=1000
GATEWAY_RATE_LIMIT_PER_IP=60
GATEWAY_RATE_LIMIT_WINDOW=60

# 熔断配置
GATEWAY_CB_THRESHOLD=10
GATEWAY_CB_RECOVERY=60
GATEWAY_CB_TIMEOUT=30

# 开发模式（生产环境必须设为 false）
GATEWAY_ENABLE_DEV_KEY=false
GATEWAY_DEV_API_KEY=

# ============================================================
# 五、各模块配置
# ============================================================

# ---------- M0 主理人控制台 ----------
M0_PORT=8000
M0_HOST=0.0.0.0
M0_LOG_LEVEL=${YUNXI_LOG_LEVEL}

# ---------- M1 多Agent调度中心 ----------
M1_NAME=m1-scheduler
M1_PORT=8001
M1_HOST=0.0.0.0
# ⚠️ 生产环境必须修改：管理员 Token（用于内部 API 调用鉴权）
M1_ADMIN_TOKEN=CHANGEME_M1_ADMIN_TOKEN_32CHARS
# ⚠️ 生产环境必须修改：加密密钥（32字节十六进制）
M1_ENCRYPTION_KEY=CHANGEME_M1_ENCRYPTION_KEY_64HEX
# ⚠️ 生产环境必须修改：JWT 签名密钥
M1_JWT_SECRET=CHANGEME_M1_JWT_SECRET_64CHARS
M1_DATABASE_URL=sqlite:///${YUNXI_DATA_DIR}/m1.db
M1_LOG_LEVEL=${YUNXI_LOG_LEVEL}

# 联邦调度密钥
# ⚠️ 生产环境必须修改
FEDERATION_MASTER_KEY=CHANGEME_FED_MASTER_KEY_64CHARS
FEDERATION_ADMIN_KEY=CHANGEME_FED_ADMIN_KEY_32CHARS
FEDERATION_INTERNAL_SECRET=CHANGEME_FED_INTERNAL_SECRET_64CHARS

# ---------- M2 技能集群 ----------
M2_NAME=m2-skills
M2_PORT=8002
M2_HOST=0.0.0.0
# ⚠️ 生产环境必须修改：管理员 Token
