# ============================================================
# 云汐系统 - 全局配置文件
# 所有模块的配置集中在这里，模块启动时自动加载
# ============================================================

# ---------- 全局基础配置 ----------
YUNXI_ENV=development
YUNXI_VERSION=1.0.0
YUNXI_LOG_LEVEL=info

# ---------- 大模型配置 ----------
# LLM_PROVIDER: deepseek / openai / ollama
# 使用本地千问大模型（Ollama）
LLM_PROVIDER=ollama
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_TIMEOUT=60

# 嵌入模型
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# 本地 Ollama 配置（LLM_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=5m
# Ollama 嵌入模型（用于向量检索）
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# 可用模型列表（供前端选择）
OLLAMA_AVAILABLE_MODELS=qwen2.5:7b,qwen2.5:14b,qwen2.5:1.5b

# ---------- M1 调度中心 ----------
M1_NAME=m1-scheduler
M1_PORT=8001
M1_HOST=0.0.0.0
M1_ADMIN_TOKEN=yunxi-m1-admin-token-2026
M1_ENCRYPTION_KEY=yunxi-m1-encryption-key-32chars!
M1_JWT_SECRET=yunxi-m1-jwt-secret-2026
M1_DATABASE_URL=sqlite:///../data/m1.db

# 联邦调度密钥
FEDERATION_MASTER_KEY=yunxi-fed-master-key-2026
FEDERATION_ADMIN_KEY=yunxi-fed-admin-key-2026
FEDERATION_INTERNAL_SECRET=yunxi-fed-internal-secret

# ---------- M2 技能集群 ----------
M2_NAME=m2-skills
M2_PORT=8002
M2_HOST=0.0.0.0
M2_ADMIN_TOKEN=yunxi-m2-admin-token-2026
M2_ENV=development
M2_DATABASE_PATH=../data/m2.db

# ---------- M3 端云协同 ----------
M3_NAME=m3-sync
M3_PORT=8003
M3_HOST=0.0.0.0
M3_ADMIN_TOKEN=yunxi-m3-admin-token-2026
M3_ENCRYPTION_KEY=yunxi-m3-encryption-key-32!
M3_DATABASE_PATH=../data/m3.db

# ---------- M4 场景引擎 ----------
M4_NAME=m4-scenes
M4_PORT=8004
M4_HOST=0.0.0.0
M4_ADMIN_TOKEN=yunxi-m4-admin-token-2026
M4_ENCRYPTION_KEY=yunxi-m4-encryption-key-32!
M4_JWT_SECRET=yunxi-m4-jwt-secret-2026
M4_DATABASE_PATH=../data/m4.db

# ---------- M5 潮汐记忆 ----------
M5_NAME=m5-memory
M5_PORT=8005
M5_HOST=0.0.0.0
M5_ADMIN_TOKEN=yunxi-m5-admin-token-2026
M5_ENCRYPTION_KEY=yunxi-m5-encryption-key-32chars!
M5_JWT_SECRET=yunxi-m5-jwt-secret-2026
M5_DATABASE_PATH=../data/m5.db
M5_VECTOR_DB_PATH=../data/m5-vector

# ---------- M6 硬件外设 ----------
M6_NAME=m6-hardware
M6_PORT=8006
M6_HOST=0.0.0.0
M6_ADMIN_TOKEN=yunxi-m6-admin-token-2026
M6_SIMULATION_MODE=true
M6_DATABASE_PATH=../data/m6.db

# ---------- M7 积木平台 ----------
M7_NAME=m7-blocks
M7_PORT=8007
M7_FRONTEND_PORT=5173
M7_ADMIN_TOKEN=yunxi-m7-admin-token-2026
M7_DATABASE_PATH=../data/m7.db

# ---------- M8 管理工作台 ----------
M8_NAME=m8-control-tower
M8_BACKEND_PORT=8008
M8_FRONTEND_PORT=5174
M8_ADMIN_TOKEN=yunxi-m8-admin-token-2026
M8_ADMIN_USERNAME=admin
M8_ADMIN_PASSWORD=admin123456
M8_JWT_SECRET=yunxi-m8-jwt-secret-2026
M8_DATABASE_PATH=../data/m8.db

# ---------- M9 编程开发 ----------
M9_HOST=0.0.0.0
M9_PORT=8009
M9_BASE_URL=http://localhost:8009
M9_ADMIN_TOKEN=yunxi-m9-admin-token-2026

# ---------- 模块间调用配置 ----------
# 各模块的 base URL（内部调用用）
M1_BASE_URL=http://localhost:8001
M2_BASE_URL=http://localhost:8002
M3_BASE_URL=http://localhost:8003
M4_BASE_URL=http://localhost:8004
M5_BASE_URL=http://localhost:8005
M6_BASE_URL=http://localhost:8006
M7_BASE_URL=http://localhost:8007

# ---------- M12 安全盾 ----------
# 开发环境 JWT 密钥，生产环境请替换为强随机密钥
M12_JWT_SECRET=yunxi-dev-secret-do-not-use-in-production-20260714

# ---------- 安全配置 ----------
CORS_ORIGINS=*
REQUEST_TIMEOUT=30
MAX_RETRY=3
RETRY_DELAY=1
