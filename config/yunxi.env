# ============================================================
# 云汐系统 - 全局配置文件
# 所有模块的配置集中在这里，模块启动时自动加载
# ============================================================

# ---------- 全局基础配置 ----------
YUNXI_ENV=development
YUNXI_VERSION=1.0.0
YUNXI_LOG_LEVEL=info

# ---------- 大模型配置 ----------
# LLM_PROVIDER: deepseek / openai / ollama
# 使用本地千问大模型（Ollama）
LLM_PROVIDER=ollama
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_TIMEOUT=60

# 嵌入模型
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# 本地 Ollama 配置（LLM_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=5m
# Ollama 嵌入模型（用于向量检索）
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# 可用模型列表（供前端选择）
OLLAMA_AVAILABLE_MODELS=qwen2.5:7b,qwen2.5:14b,qwen2.5:1.5b

# ---------- M4 代码生成 LLM 配置 ----------
# 启用 LLM 代码生成（M4 场景引擎的 work_dev 模块）
M4_ENABLE_LLM=true
# LLM 代码生成专用端点（兼容 OpenAI Chat Completions 格式）
LLM_CODEGEN_URL=http://localhost:11434/v1/chat/completions
# LLM 代码生成专用模型（推荐使用代码专用模型）
LLM_CODEGEN_MODEL=qwen2.5:7b

# ---------- M1 调度中心 ----------
M1_NAME=m1-scheduler
M1_PORT=8001
M1_HOST=0.0.0.0
M1_ADMIN_TOKEN=yunxi-m1-admin-token-2026
M1_ENCRYPTION_KEY=yunxi-m1-encryption-key-32chars!
M1_JWT_SECRET=yunxi-m1-jwt-secret-2026
M1_DATABASE_URL=sqlite:///../data/m1.db

# 联邦调度密钥
FEDERATION_MASTER_KEY=yunxi-fed-master-key-2026
FEDERATION_ADMIN_KEY=yunxi-fed-admin-key-2026
FEDERATION_INTERNAL_SECRET=yunxi-fed-internal-secret

# ---------- M2 技能集群 ----------
M2_NAME=m2-skills
M2_PORT=8002
M2_HOST=0.0.0.0
M2_ADMIN_TOKEN=yunxi-m2-admin-token-2026
M2_ENV=development
M2_DATABASE_PATH=../data/m2.db

# ---------- M3 端云协同 ----------
M3_NAME=m3-sync
M3_PORT=8003
M3_HOST=0.0.0.0
M3_ADMIN_TOKEN=yunxi-m3-admin-token-2026
M3_ENCRYPTION_KEY=yunxi-m3-encryption-key-32!
M3_DATABASE_PATH=../data/m3.db

# ---------- M4 场景引擎 ----------
M4_NAME=m4-scenes
M4_PORT=8004
M4_HOST=0.0.0.0
M4_ADMIN_TOKEN=yunxi-m4-admin-token-2026
M4_ENCRYPTION_KEY=yunxi-m4-encryption-key-32!
M4_JWT_SECRET=yunxi-m4-jwt-secret-2026
M4_DATABASE_PATH=../data/m4.db

# ---------- M5 潮汐记忆 ----------
M5_NAME=m5-memory
M5_PORT=8005
M5_HOST=0.0.0.0
M5_ADMIN_TOKEN=yunxi-m5-admin-token-2026
M5_ENCRYPTION_KEY=yunxi-m5-encryption-key-32chars!
M5_JWT_SECRET=yunxi-m5-jwt-secret-2026
M5_DATABASE_PATH=../data/m5.db
M5_VECTOR_DB_PATH=../data/m5-vector

# ---------- M6 硬件外设 ----------
M6_NAME=m6-hardware
M6_PORT=8006
M6_HOST=0.0.0.0
M6_ADMIN_TOKEN=yunxi-m6-admin-token-2026
M6_SIMULATION_MODE=true
M6_DATABASE_PATH=../data/m6.db

# ---------- M7 积木平台 ----------
M7_NAME=m7-blocks
M7_PORT=8007
M7_FRONTEND_PORT=5173
M7_ADMIN_TOKEN=yunxi-m7-admin-token-2026
M7_DATABASE_PATH=../data/m7.db

# ---------- M8 管理工作台 ----------
M8_NAME=m8-control-tower
M8_BACKEND_PORT=8008
M8_FRONTEND_PORT=5174
M8_PORT=8008
M8_ADMIN_TOKEN=yunxi-m8-admin-token-2026
M8_ADMIN_USERNAME=admin
M8_ADMIN_PASSWORD=admin123456
M8_JWT_SECRET=yunxi-m8-jwt-secret-2026
M8_DATABASE_PATH=../data/m8.db

# ---------- M9 编程开发 ----------
M9_HOST=0.0.0.0
M9_PORT=8009
M9_BASE_URL=http://localhost:8009
M9_ADMIN_TOKEN=yunxi-m9-admin-token-2026

# ---------- 模块间调用配置 ----------
# 各模块的 base URL（内部调用用）
M1_BASE_URL=http://localhost:8001
M2_BASE_URL=http://localhost:8002
M3_BASE_URL=http://localhost:8003
M4_BASE_URL=http://localhost:8004
M5_BASE_URL=http://localhost:8005
M6_BASE_URL=http://localhost:8006
M7_BASE_URL=http://localhost:8007

# ---------- M12 安全盾 ----------
# 开发环境 JWT 密钥，生产环境请替换为强随机密钥
M12_JWT_SECRET=yunxi-dev-secret-do-not-use-in-production-20260714

# ---------- M10 系统卫士 ----------
M10_PORT=8010

# ---------- M11 MCP 总线 ----------
M11_PORT=8011

# ---------- M12 安全盾 ----------
M12_PORT=8012

# ---------- M0 主理人控制台 ----------
M0_PORT=8000

# ---------- WAF 安全防护配置 ----------
# 是否启用 WAF Web 应用防火墙（默认启用）
WAF_ENABLED=true
# WAF 工作模式：monitor（检测模式，只日志不拦截）/ block（拦截模式，发现攻击返回403）
WAF_MODE=monitor
# 启用的规则类型，逗号分隔，可选值：sql_injection,xss,command_injection,path_traversal,csrf
# 留空表示启用全部规则
WAF_RULE_TYPES=
# 排除的路径（逗号分隔），这些路径不经过 WAF 检测
WAF_EXCLUDE_PATHS=/health,/m8/health,/m8/metrics,/m8/config
# 请求体检测大小限制（KB），超过此大小的请求体不参与检测
WAF_BODY_LIMIT_KB=10

# ---------- 安全配置 ----------
# CORS 允许来源（逗号分隔）
# ⚠️ 安全说明：
#   - 开发环境: 配置为 "*" 或留空时，自动使用 localhost 常用端口列表，并输出警告日志
#   - 生产环境: 必须显式配置具体域名，禁止使用 "*"，否则启动失败
#   - allow_credentials=True 时，origins 绝对不能为 "*"（浏览器规范 + CSRF 风险）
CORS_ORIGINS=*
REQUEST_TIMEOUT=30
MAX_RETRY=3
RETRY_DELAY=1

# ---------- API Gateway 网关配置（v2.0 - 12模块全量路由） ----------
# 网关端口（统一接入层，外部请求统一通过网关访问各模块）
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0
GATEWAY_LOG_LEVEL=info

# 网关 CORS（独立配置，优先级高于全局 CORS_ORIGINS）
# 生产环境必须配置具体域名，禁止使用 "*"
GATEWAY_CORS_ORIGINS=

# 网关认证 - JWT 密钥（与 M8/M12 保持一致）
GATEWAY_JWT_SECRET=yunxi-m8-jwt-secret-2026
GATEWAY_JWT_ALGORITHM=HS256
GATEWAY_JWT_ISSUER=yunxi

# 网关 API Key 头字段名
GATEWAY_API_KEY_HEADER=X-API-Key
GATEWAY_JWT_HEADER=Authorization

# 网关 API Key（服务间调用认证，生产环境请替换）
# 可配置多个：GATEWAY_API_KEY_1, GATEWAY_API_KEY_2, ..., GATEWAY_API_KEY_20
GATEWAY_API_KEY_1=yunxi-gateway-key-2026-change-in-production
# GATEWAY_API_KEY_2=your-second-api-key
# GATEWAY_API_KEY_3=your-third-api-key

# 开发环境专用 Key（⚠️ 仅开发环境可用，生产环境请禁用）
# 设置为 true 启用 GATEWAY_DEV_API_KEY
GATEWAY_ENABLE_DEV_KEY=true
GATEWAY_DEV_API_KEY=yunxi-gateway-dev-key

# 网关限流配置（全局默认值）
# 各模块可在路由配置中独立覆盖
GATEWAY_RATE_LIMIT_TOTAL=600
GATEWAY_RATE_LIMIT_PER_IP=100

# 网关熔断配置（全局默认值）
# 各模块可在路由配置中独立覆盖
GATEWAY_CB_THRESHOLD=5
GATEWAY_CB_RECOVERY=30

# ---------- 12 模块路由基础 URL（网关转发目标） ----------
# 本地开发环境默认值，Docker 部署时由 docker-compose 覆盖
# M1 多Agent调度中心
M1_BASE_URL=http://localhost:8001
# M2 技能集群
M2_BASE_URL=http://localhost:8002
# M3 端云协同内核
M3_BASE_URL=http://localhost:8003
# M4 场景引擎
M4_BASE_URL=http://localhost:8004
# M5 潮汐记忆系统
M5_BASE_URL=http://localhost:8005
# M6 硬件外设模拟
M6_BASE_URL=http://localhost:8006
# M7 积木平台
M7_BASE_URL=http://localhost:8007
# M8 管理控制塔
M8_BASE_URL=http://localhost:8008
# M9 开发者工坊
M9_BASE_URL=http://localhost:8009
# M10 系统卫士
M10_BASE_URL=http://localhost:8010
# M11 MCP总线
M11_BASE_URL=http://localhost:8011
# M12 安全盾
M12_BASE_URL=http://localhost:8012

# ---------- 网关管理 API 说明 ----------
# GET    /gateway/health              - 网关健康检查
# GET    /gateway/routes              - 查看所有路由配置
# GET    /gateway/routes/{key}        - 查看单个路由详情
# GET    /gateway/status              - 网关状态（模块健康+熔断器）
# GET    /gateway/metrics             - 网关指标（请求量/延迟/错误率）
# POST   /gateway/routes/reload       - 重新加载所有路由
# POST   /gateway/routes/{key}/reload - 重新加载指定路由
# POST   /gateway/circuit-breakers/reset       - 重置所有熔断器
# POST   /gateway/circuit-breakers/{key}/reset - 重置指定模块熔断器
#
# 兼容旧路径：
# GET    /health         -> /gateway/health
# GET    /m8/health      -> /gateway/status
# GET    /m8/metrics     -> /gateway/metrics
# GET    /routes         -> /gateway/routes

# ---------- M8 备份调度中心配置（第二阶段统一治理） ----------
# 是否启用统一备份调度
BACKUP_ENABLED=true
# 备份根目录（相对于项目根目录）
BACKUP_ROOT=backups
# 默认备份类型：full（全量）/ incremental（增量）/ differential（差异）
BACKUP_DEFAULT_TYPE=full
# 默认压缩类型：gzip / none
BACKUP_COMPRESSION=gzip
# 默认加密类型：aes-256-gcm / none
BACKUP_ENCRYPTION=none
# 加密密钥（base64编码的32字节密钥，启用加密时必填）
BACKUP_ENCRYPTION_KEY=
# 默认保留策略：count（按数量）/ age（按时间）/ size（按大小）/ hybrid（混合）
BACKUP_RETENTION_STRATEGY=hybrid
# 最大保留备份数
BACKUP_MAX_BACKUPS=30
# 最大保留天数
BACKUP_MAX_AGE_DAYS=30
# 最大存储空间（GB）
BACKUP_MAX_SIZE_GB=50
# 备份失败告警阈值（连续失败次数）
BACKUP_ALERT_FAILURE_THRESHOLD=3
# 磁盘空间告警阈值（%）
BACKUP_DISK_WARN_PERCENT=20
BACKUP_DISK_CRITICAL_PERCENT=10
# 存储监控间隔（秒）
BACKUP_STORAGE_MONITOR_INTERVAL=3600

# ---------- 各模块备份策略覆盖 ----------
# M4 场景引擎
BACKUP_M4_ENABLED=true
BACKUP_M4_SCHEDULE=daily
BACKUP_M4_TIME=03:00
BACKUP_M4_MAX_BACKUPS=30

# M5 潮汐记忆
BACKUP_M5_ENABLED=true
BACKUP_M5_SCHEDULE=daily
BACKUP_M5_TIME=03:30
BACKUP_M5_MAX_BACKUPS=30

# M6 硬件外设
BACKUP_M6_ENABLED=true
