# ============================================================
# 云汐系统 - 全局配置文件（示例模板）
# 所有模块的配置集中在这里，模块启动时自动加载
#
# ⚠️  安全提示：
# 1. 复制本文件为 yunxi.env 后再修改
# 2. 生产环境必须替换所有 CHANGEME_ 开头的密钥为强随机值
# 3. 推荐使用 openssl rand -hex 32 生成密钥
# 4. yunxi.env 已在 .gitignore 中，不会被提交到仓库
# 5. 密钥长度建议：JWT_SECRET >= 32字节，API_TOKEN >= 16字节
# ============================================================

# ---------- 全局基础配置 ----------
YUNXI_ENV=development
YUNXI_VERSION=1.0.0
YUNXI_LOG_LEVEL=info

# ---------- 大模型配置 ----------
# LLM_PROVIDER: deepseek / openai / ollama
# 使用本地千问大模型（Ollama）
LLM_PROVIDER=ollama
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_TIMEOUT=60

# 嵌入模型
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# 本地 Ollama 配置（LLM_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=5m
# Ollama 嵌入模型（用于向量检索）
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# 可用模型列表（供前端选择）
OLLAMA_AVAILABLE_MODELS=qwen2.5:7b,qwen2.5:14b,qwen2.5:1.5b

# ---------- M4 代码生成 LLM 配置 ----------
# 启用 LLM 代码生成（M4 场景引擎的 work_dev 模块）
M4_ENABLE_LLM=true
# LLM 代码生成专用端点（兼容 OpenAI Chat Completions 格式）
LLM_CODEGEN_URL=http://localhost:11434/v1/chat/completions
# LLM 代码生成专用模型（推荐使用代码专用模型）
LLM_CODEGEN_MODEL=qwen2.5:7b

# ---------- M1 调度中心 ----------
M1_NAME=m1-scheduler
M1_PORT=8001
M1_HOST=0.0.0.0
# ⚠️ 生产环境必须修改：管理员 Token（用于内部 API 调用鉴权）
M1_ADMIN_TOKEN=CHANGEME_M1_ADMIN_TOKEN_32CHARS
# ⚠️ 生产环境必须修改：加密密钥（32字节）
M1_ENCRYPTION_KEY=CHANGEME_M1_ENCRYPTION_KEY_32CHARS
# ⚠️ 生产环境必须修改：JWT 签名密钥
M1_JWT_SECRET=CHANGEME_M1_JWT_SECRET_32CHARS
M1_DATABASE_URL=sqlite:///../data/m1.db

# 联邦调度密钥
# ⚠️ 生产环境必须修改
FEDERATION_MASTER_KEY=CHANGEME_FED_MASTER_KEY
FEDERATION_ADMIN_KEY=CHANGEME_FED_ADMIN_KEY
FEDERATION_INTERNAL_SECRET=CHANGEME_FED_INTERNAL_SECRET

# ---------- M2 技能集群 ----------
M2_NAME=m2-skills
M2_PORT=8002
M2_HOST=0.0.0.0
# ⚠️ 生产环境必须修改：管理员 Token
M2_ADMIN_TOKEN=CHANGEME_M2_ADMIN_TOKEN_32CHARS
M2_ENV=development
M2_DATABASE_PATH=../data/m2.db

# ---------- M3 端云协同 ----------
M3_NAME=m3-sync
M3_PORT=8003
M3_HOST=0.0.0.0
# ⚠️ 生产环境必须修改：管理员 Token
M3_ADMIN_TOKEN=CHANGEME_M3_ADMIN_TOKEN_32CHARS
# ⚠️ 生产环境必须修改：加密密钥
M3_ENCRYPTION_KEY=CHANGEME_M3_ENCRYPTION_KEY_32CHARS
M3_DATABASE_PATH=../data/m3.db

# ---------- M4 场景引擎 ----------
M4_NAME=m4-scenes
M4_PORT=8004
M4_HOST=0.0.0.0
# ⚠️ 生产环境必须修改：管理员 Token
M4_ADMIN_TOKEN=CHANGEME_M4_ADMIN_TOKEN_32CHARS
# ⚠️ 生产环境必须修改：加密密钥
M4_ENCRYPTION_KEY=CHANGEME_M4_ENCRYPTION_KEY_32CHARS
# ⚠️ 生产环境必须修改：JWT 签名密钥
M4_JWT_SECRET=CHANGEME_M4_JWT_SECRET_32CHARS
M4_DATABASE_PATH=../data/m4.db

# ---------- M5 潮汐记忆 ----------
M5_NAME=m5-memory
M5_PORT=8005
M5_HOST=0.0.0.0
# ⚠️ 生产环境必须修改：管理员 Token
M5_ADMIN_TOKEN=CHANGEME_M5_ADMIN_TOKEN_32CHARS
# ⚠️ 生产环境必须修改：加密密钥
M5_ENCRYPTION_KEY=CHANGEME_M5_ENCRYPTION_KEY_32CHARS
# ⚠️ 生产环境必须修改：JWT 签名密钥
M5_JWT_SECRET=CHANGEME_M5_JWT_SECRET_32CHARS
M5_DATABASE_PATH=../data/m5.db
M5_VECTOR_DB_PATH=../data/m5-vector

# ---------- M6 硬件外设 ----------
M6_NAME=m6-hardware
M6_PORT=8006
M6_HOST=0.0.0.0
# ⚠️ 生产环境必须修改：管理员 Token
M6_ADMIN_TOKEN=CHANGEME_M6_ADMIN_TOKEN_32CHARS
M6_SIMULATION_MODE=true
M6_DATABASE_PATH=../data/m6.db

# ---------- M7 积木平台 ----------
M7_NAME=m7-blocks
M7_PORT=8007
M7_FRONTEND_PORT=5173
# ⚠️ 生产环境必须修改：管理员 Token
M7_ADMIN_TOKEN=CHANGEME_M7_ADMIN_TOKEN_32CHARS
M7_DATABASE_PATH=../data/m7.db

# ---------- M8 管理工作台 ----------
M8_NAME=m8-control-tower
M8_BACKEND_PORT=8008
M8_FRONTEND_PORT=5174
M8_PORT=8008
# ⚠️ 生产环境必须修改：管理员 Token
M8_ADMIN_TOKEN=CHANGEME_M8_ADMIN_TOKEN_32CHARS
M8_ADMIN_USERNAME=admin
# ⚠️ 生产环境必须修改：默认管理员密码（首次登录后请修改）
M8_ADMIN_PASSWORD=CHANGEME_ADMIN_PASSWORD_STRONG
# ⚠️ 生产环境必须修改：JWT 签名密钥
M8_JWT_SECRET=CHANGEME_M8_JWT_SECRET_32CHARS
M8_DATABASE_PATH=../data/m8.db

# ---------- M9 编程开发 ----------
M9_HOST=0.0.0.0
M9_PORT=8009
M9_BASE_URL=http://localhost:8009
# ⚠️ 生产环境必须修改：管理员 Token
M9_ADMIN_TOKEN=CHANGEME_M9_ADMIN_TOKEN_32CHARS

# ---------- 模块间调用配置 ----------
# 各模块的 base URL（内部调用用）
M1_BASE_URL=http://localhost:8001
M2_BASE_URL=http://localhost:8002
M3_BASE_URL=http://localhost:8003
M4_BASE_URL=http://localhost:8004
M5_BASE_URL=http://localhost:8005
M6_BASE_URL=http://localhost:8006
M7_BASE_URL=http://localhost:8007

# ---------- M12 安全盾 ----------
# ⚠️ 生产环境必须替换为强随机密钥（至少32字节）
M12_JWT_SECRET=CHANGEME_M12_JWT_SECRET_32CHARS

# ---------- M10 系统卫士 ----------
M10_PORT=8010

# ---------- M11 MCP 总线 ----------
M11_PORT=8011

# ---------- M12 安全盾 ----------
M12_PORT=8012

# ---------- M0 主理人控制台 ----------
M0_PORT=8000

# ---------- WAF 安全防护配置 ----------
# 是否启用 WAF Web 应用防火墙（默认启用）
WAF_ENABLED=true
# WAF 工作模式：monitor（检测模式，只日志不拦截）/ block（拦截模式，发现攻击返回403）
# 生产环境建议先使用 monitor 模式观察，确认无误后再切换到 block
WAF_MODE=monitor
# 启用的规则类型，逗号分隔，可选值：sql_injection,xss,command_injection,path_traversal,csrf
# 留空表示启用全部规则
WAF_RULE_TYPES=
# 排除的路径（逗号分隔），这些路径不经过 WAF 检测
WAF_EXCLUDE_PATHS=/health,/m8/health,/m8/metrics,/m8/config
# 请求体检测大小限制（KB），超过此大小的请求体不参与检测
WAF_BODY_LIMIT_KB=10

# ---------- 安全配置 ----------
# ⚠️ 生产环境建议限制为具体域名，不要使用 *
CORS_ORIGINS=*
REQUEST_TIMEOUT=30
MAX_RETRY=3
RETRY_DELAY=1

# ---------- API Gateway 配置 ----------
# ⚠️ 生产环境必须修改：JWT 签名密钥（与各模块保持一致或独立配置）
GATEWAY_JWT_SECRET=CHANGEME_GATEWAY_JWT_SECRET_32CHARS
# ⚠️ 生产环境必须配置：API Key（用于服务间调用）
GATEWAY_API_KEY_1=CHANGEME_GATEWAY_API_KEY_1
