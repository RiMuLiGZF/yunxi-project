# ============================================================
# 云汐系统 - 全局环境变量配置模板
# ============================================================
#
# 使用方法：
#   1. 复制本文件为 yunxi.env： cp .env.example yunxi.env
#   2. 根据实际环境修改配置值
#   3. 所有以 CHANGEME_ 开头的字段必须替换为真实值
#
# 安全提示：
#   - yunxi.env 已在 .gitignore 中，不会被提交到仓库
#   - 生产环境必须替换所有 CHANGEME_ 开头的密钥为强随机值
#   - 推荐生成密钥命令：
#       Linux/Mac:  openssl rand -hex 32
#       PowerShell: -join ((1..32) | % { '{0:x2}' -f (Get-Random -Max 256) })
#   - 密钥长度建议：
#       JWT_SECRET     >= 32 字节（推荐 64 字节）
#       ENCRYPTION_KEY  = 32 字节（AES-256 需要正好 32 字节）
#       ADMIN_TOKEN    >= 32 字节
#       API_KEY        >= 32 字节
#   - 生产环境务必设置文件权限，仅允许服务账户读取
#
# 测试环境安全注意事项（SEC-008）：
#   - .env.test 已在 .gitignore 中，禁止提交到代码仓库
#   - 测试环境密码必须使用随机强密码，禁止使用 admin123456 等弱密码
#   - 测试环境 JWT 密钥必须与生产环境不同
#   - CI/CD 流水线中应从环境变量或密钥管理系统注入测试配置
#   - 测试数据库必须与开发/生产环境数据隔离
#   - 测试账号仅限测试环境使用，不得复用生产环境凭证
#
# ============================================================


# ============================================================
# 一、全局基础配置
# ============================================================

# 运行环境：development / staging / production / testing
YUNXI_ENV=development

# 系统版本号
YUNXI_VERSION=1.0.0

# 日志级别：debug / info / warning / error / critical
YUNXI_LOG_LEVEL=info


# ============================================================
# 二、大模型配置
# ============================================================

# LLM 提供商: deepseek / openai / ollama / azure
LLM_PROVIDER=ollama

# LLM API 密钥（外部服务密钥，生产环境务必填写真实密钥）
# 本地 Ollama 可留空或填任意值
LLM_API_KEY=CHANGEME_LLM_API_KEY

# API 基础地址
LLM_BASE_URL=http://localhost:11434/v1

# 默认模型
LLM_MODEL=qwen2.5:7b

# 请求超时时间（秒）
LLM_TIMEOUT=60

# 嵌入模型
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# 本地 Ollama 配置（LLM_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=5m
# Ollama 嵌入模型（用于向量检索）
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# 可用模型列表（供前端选择）
OLLAMA_AVAILABLE_MODELS=qwen2.5:7b,qwen2.5:14b,qwen2.5:1.5b


# ============================================================
# 三、M4 代码生成 LLM 配置
# ============================================================

# 启用 LLM 代码生成（M4 场景引擎的 work_dev 模块）
M4_ENABLE_LLM=true
# LLM 代码生成专用端点（兼容 OpenAI Chat Completions 格式）
LLM_CODEGEN_URL=http://localhost:11434/v1/chat/completions
# LLM 代码生成专用模型（推荐使用代码专用模型）
LLM_CODEGEN_MODEL=qwen2.5:7b


# ============================================================
# 四、M1 多Agent调度中心
# ============================================================

M1_NAME=m1-scheduler
M1_PORT=8001
M1_HOST=0.0.0.0
# 管理员 Token（用于内部 API 调用鉴权，生产环境必须修改）
M1_ADMIN_TOKEN=CHANGEME_M1_ADMIN_TOKEN_32CHARS
# 加密密钥（AES-256 需要正好 32 字节，生产环境必须修改）
M1_ENCRYPTION_KEY=CHANGEME_M1_ENCRYPTION_KEY_32CHARS
# JWT 签名密钥（生产环境必须修改，至少 32 字节）
M1_JWT_SECRET=CHANGEME_M1_JWT_SECRET_32CHARS
M1_DATABASE_URL=sqlite:///../data/m1.db

# 联邦调度密钥（生产环境必须修改）
FEDERATION_MASTER_KEY=CHANGEME_FED_MASTER_KEY_32CHARS
FEDERATION_ADMIN_KEY=CHANGEME_FED_ADMIN_KEY_32CHARS
FEDERATION_INTERNAL_SECRET=CHANGEME_FED_INTERNAL_SECRET_32CHARS


# ============================================================
# 五、M2 技能集群
# ============================================================

M2_NAME=m2-skills
M2_PORT=8002
M2_HOST=0.0.0.0
# 管理员 Token（生产环境必须修改）
M2_ADMIN_TOKEN=CHANGEME_M2_ADMIN_TOKEN_32CHARS
M2_ENV=development
M2_DATABASE_PATH=../data/m2.db


# ============================================================
# 六、M3 端云协同
# ============================================================

M3_NAME=m3-sync
M3_PORT=8003
M3_HOST=0.0.0.0
# 管理员 Token（生产环境必须修改）
M3_ADMIN_TOKEN=CHANGEME_M3_ADMIN_TOKEN_32CHARS
# 加密密钥（生产环境必须修改，32 字节）
M3_ENCRYPTION_KEY=CHANGEME_M3_ENCRYPTION_KEY_32CHARS
M3_DATABASE_PATH=../data/m3.db


# ============================================================
# 七、M4 场景引擎
# ============================================================

M4_NAME=m4-scenes
M4_PORT=8004
M4_HOST=0.0.0.0
# 管理员 Token（生产环境必须修改）
M4_ADMIN_TOKEN=CHANGEME_M4_ADMIN_TOKEN_32CHARS
# 加密密钥（生产环境必须修改，32 字节）
M4_ENCRYPTION_KEY=CHANGEME_M4_ENCRYPTION_KEY_32CHARS
# JWT 签名密钥（生产环境必须修改，至少 32 字节）
M4_JWT_SECRET=CHANGEME_M4_JWT_SECRET_32CHARS
M4_DATABASE_PATH=../data/m4.db


# ============================================================
# 八、M5 潮汐记忆
# ============================================================

M5_NAME=m5-memory
M5_PORT=8005
M5_HOST=0.0.0.0
# 管理员 Token（生产环境必须修改）
M5_ADMIN_TOKEN=CHANGEME_M5_ADMIN_TOKEN_32CHARS
# 加密密钥（生产环境必须修改，32 字节）
M5_ENCRYPTION_KEY=CHANGEME_M5_ENCRYPTION_KEY_32CHARS
# JWT 签名密钥（生产环境必须修改，至少 32 字节）
M5_JWT_SECRET=CHANGEME_M5_JWT_SECRET_32CHARS
M5_DATABASE_PATH=../data/m5.db
M5_VECTOR_DB_PATH=../data/m5-vector


# ============================================================
# 九、M6 硬件外设
# ============================================================

M6_NAME=m6-hardware
M6_PORT=8006
M6_HOST=0.0.0.0
# 管理员 Token（生产环境必须修改）
M6_ADMIN_TOKEN=CHANGEME_M6_ADMIN_TOKEN_32CHARS
M6_SIMULATION_MODE=true
M6_DATABASE_PATH=../data/m6.db


# ============================================================
# 十、M7 积木平台
# ============================================================

M7_NAME=m7-blocks
M7_PORT=8007
M7_FRONTEND_PORT=5173
# 管理员 Token（生产环境必须修改）
M7_ADMIN_TOKEN=CHANGEME_M7_ADMIN_TOKEN_32CHARS
M7_DATABASE_PATH=../data/m7.db


# ============================================================
# 十一、M8 管理工作台
# ============================================================

M8_NAME=m8-control-tower
M8_BACKEND_PORT=8008
M8_FRONTEND_PORT=5174
M8_PORT=8008
# 管理员 Token（生产环境必须修改）
M8_ADMIN_TOKEN=CHANGEME_M8_ADMIN_TOKEN_32CHARS
M8_ADMIN_USERNAME=admin
# 默认管理员密码（生产环境必须修改，首次登录后请立即修改）
M8_ADMIN_PASSWORD=CHANGEME_ADMIN_PASSWORD_STRONG
# JWT 签名密钥（生产环境必须修改，至少 32 字节）
M8_JWT_SECRET=CHANGEME_M8_JWT_SECRET_32CHARS
M8_DATABASE_PATH=../data/m8.db


# ============================================================
# 十二、M9 编程开发
# ============================================================

M9_HOST=0.0.0.0
M9_PORT=8009
M9_BASE_URL=http://localhost:8009
# 管理员 Token（生产环境必须修改）
M9_ADMIN_TOKEN=CHANGEME_M9_ADMIN_TOKEN_32CHARS


# ============================================================
# 十三、M10 系统卫士
# ============================================================

M10_PORT=8010
M10_HOST=0.0.0.0
# 管理员 Token（生产环境必须修改）
M10_ADMIN_TOKEN=CHANGEME_M10_ADMIN_TOKEN_32CHARS


# ============================================================
# 十四、M11 MCP 总线
# ============================================================

M11_PORT=8011
M11_HOST=0.0.0.0
# 管理员 Token（生产环境必须修改）
M11_ADMIN_TOKEN=CHANGEME_M11_ADMIN_TOKEN_32CHARS
# MCP 默认 API Key（生产环境必须修改，至少 32 字节）
M11_MCP_DEFAULT_API_KEY=CHANGEME_M11_MCP_API_KEY_32CHARS
# 是否启用 MCP 端点鉴权（生产环境必须启用）
M11_MCP_REQUIRE_AUTH=true


# ============================================================
# 十五、M12 安全盾
# ============================================================

M12_PORT=8012
M12_HOST=0.0.0.0
# JWT 签名密钥（生产环境必须替换为强随机密钥，至少 32 字节）
M12_JWT_SECRET=CHANGEME_M12_JWT_SECRET_32CHARS
# 管理员 Token（生产环境必须修改）
M12_ADMIN_TOKEN=CHANGEME_M12_ADMIN_TOKEN_32CHARS


# ============================================================
# 十六、M0 主理人控制台
# ============================================================

M0_PORT=8000
M0_HOST=0.0.0.0


# ============================================================
# 十七、模块间调用配置
# ============================================================
# 各模块的 base URL（内部调用用，Docker 部署时修改为容器名）

M1_BASE_URL=http://localhost:8001
M2_BASE_URL=http://localhost:8002
M3_BASE_URL=http://localhost:8003
M4_BASE_URL=http://localhost:8004
M5_BASE_URL=http://localhost:8005
M6_BASE_URL=http://localhost:8006
M7_BASE_URL=http://localhost:8007
M8_BASE_URL=http://localhost:8008
M9_BASE_URL=http://localhost:8009
M10_BASE_URL=http://localhost:8010
M11_BASE_URL=http://localhost:8011
M12_BASE_URL=http://localhost:8012


# ============================================================
# 十八、WAF 安全防护配置
# ============================================================

# 是否启用 WAF Web 应用防火墙
WAF_ENABLED=true
# WAF 工作模式：monitor（检测模式，只日志不拦截）/ block（拦截模式）
WAF_MODE=monitor
# 启用的规则类型，逗号分隔，可选值：sql_injection,xss,command_injection,path_traversal,csrf
# 留空表示启用全部规则
WAF_RULE_TYPES=
# 排除的路径（逗号分隔），这些路径不经过 WAF 检测
WAF_EXCLUDE_PATHS=/health,/m8/health,/m8/metrics,/m8/config
# 请求体检测大小限制（KB）
WAF_BODY_LIMIT_KB=10


# ============================================================
# 十九、安全配置
# ============================================================

# CORS 允许来源（逗号分隔）
# 生产环境必须配置具体域名，禁止使用 "*"
CORS_ORIGINS=*
REQUEST_TIMEOUT=30
MAX_RETRY=3
RETRY_DELAY=1


# ============================================================
# 二十、API Gateway 网关配置
# ============================================================

# 网关端口
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0
GATEWAY_LOG_LEVEL=info

# 网关 CORS（独立配置，优先级高于全局 CORS_ORIGINS）
# 生产环境必须配置具体域名，禁止使用 "*"
GATEWAY_CORS_ORIGINS=

# 网关认证 - JWT 密钥（生产环境必须修改，至少 32 字节）
GATEWAY_JWT_SECRET=CHANGEME_GATEWAY_JWT_SECRET_32CHARS
GATEWAY_JWT_ALGORITHM=HS256
GATEWAY_JWT_ISSUER=yunxi

# 网关 API Key 头字段名
GATEWAY_API_KEY_HEADER=X-API-Key
GATEWAY_JWT_HEADER=Authorization

# 网关 API Key（服务间调用认证，生产环境请替换）
# 可配置多个：GATEWAY_API_KEY_1, GATEWAY_API_KEY_2, ..., GATEWAY_API_KEY_20
GATEWAY_API_KEY_1=CHANGEME_GATEWAY_API_KEY_1
# GATEWAY_API_KEY_2=your-second-api-key
# GATEWAY_API_KEY_3=your-third-api-key

# 开发环境专用 Key（仅开发环境可用，生产环境请禁用）
GATEWAY_ENABLE_DEV_KEY=true
GATEWAY_DEV_API_KEY=CHANGEME_GATEWAY_DEV_KEY

# 网关限流配置（全局默认值）
GATEWAY_RATE_LIMIT_TOTAL=600
GATEWAY_RATE_LIMIT_PER_IP=100

# 网关熔断配置（全局默认值）
GATEWAY_CB_THRESHOLD=5
GATEWAY_CB_RECOVERY=30


# ============================================================
# 二十一、备份调度配置
# ============================================================

# 是否启用统一备份调度
BACKUP_ENABLED=true
# 备份根目录（相对于项目根目录）
BACKUP_ROOT=backups
# 默认备份类型：full / incremental / differential
BACKUP_DEFAULT_TYPE=full
# 默认压缩类型：gzip / none
BACKUP_COMPRESSION=gzip
# 默认加密类型：aes-256-gcm / none
BACKUP_ENCRYPTION=none
# 加密密钥（base64 编码的 32 字节密钥，启用加密时必填）
BACKUP_ENCRYPTION_KEY=CHANGEME_BACKUP_ENCRYPTION_KEY
# 默认保留策略：count / age / size / hybrid
BACKUP_RETENTION_STRATEGY=hybrid
# 最大保留备份数
BACKUP_MAX_BACKUPS=30
# 最大保留天数
BACKUP_MAX_AGE_DAYS=30
# 最大存储空间（GB）
BACKUP_MAX_SIZE_GB=50
# 备份失败告警阈值（连续失败次数）
BACKUP_ALERT_FAILURE_THRESHOLD=3
# 磁盘空间告警阈值（%）
BACKUP_DISK_WARN_PERCENT=20
BACKUP_DISK_CRITICAL_PERCENT=10
# 存储监控间隔（秒）
BACKUP_STORAGE_MONITOR_INTERVAL=3600

# 各模块备份策略覆盖
BACKUP_M4_ENABLED=true
BACKUP_M4_SCHEDULE=daily
BACKUP_M4_TIME=03:00
BACKUP_M4_MAX_BACKUPS=30

BACKUP_M5_ENABLED=true
BACKUP_M5_SCHEDULE=daily
BACKUP_M5_TIME=03:30
BACKUP_M5_MAX_BACKUPS=30

BACKUP_M6_ENABLED=true
BACKUP_M6_SCHEDULE=daily
BACKUP_M6_TIME=04:00
BACKUP_M6_MAX_BACKUPS=20

BACKUP_M8_ENABLED=true
BACKUP_M8_SCHEDULE=daily
BACKUP_M8_TIME=02:00
BACKUP_M8_MAX_BACKUPS=50

BACKUP_M9_ENABLED=true
BACKUP_M9_SCHEDULE=daily
BACKUP_M9_TIME=03:00
BACKUP_M9_MAX_BACKUPS=30

BACKUP_M10_ENABLED=true
BACKUP_M10_SCHEDULE=daily
BACKUP_M10_TIME=04:30
BACKUP_M10_MAX_BACKUPS=30

BACKUP_M12_ENABLED=true
BACKUP_M12_SCHEDULE=daily
BACKUP_M12_TIME=05:00
BACKUP_M12_MAX_BACKUPS=30
