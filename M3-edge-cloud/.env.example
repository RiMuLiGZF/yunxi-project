# ============================================================
# M3 - 端云协同内核 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# ---- 基础配置 ----
M3_PORT=8003
M3_HOST=0.0.0.0
M3_ENV=development
YUNXI_ENV=development
YUNXI_LOG_LEVEL=info

# ---- 安全配置 ----
M3_ADMIN_TOKEN=your-m3-admin-token-here
M3_ENCRYPTION_KEY=your-m3-encryption-key-at-least-32chars

# ---- M8 标准对接 Token ----
# M8 管理平台访问 /m8/* 接口所需的鉴权 Token
# 优先级：M3_M8_TOKEN > M8_TOKEN > M3_ADMIN_TOKEN（向后兼容）
M3_M8_TOKEN=your-m3-m8-token-here
# M8_TOKEN=alternative-m8-token

# ---- 数据库 ----
M3_DATABASE_PATH=./data/m3.db

# ---- CORS ----
CORS_ORIGINS=*

# ---- 日志配置（统一日志系统） ----
# 日志级别（DEBUG / INFO / WARNING / ERROR / CRITICAL）
LOG_LEVEL=INFO
YUNXI_LOG_LEVEL=INFO

# 日志目录（默认 ./logs）
LOG_DIR=./logs
YUNXI_LOG_DIR=./logs

# 日志格式（json / text，生产环境默认 json，开发环境默认 text）
LOG_FORMAT=text
YUNXI_LOG_FORMAT=text

# 是否输出到文件（true / false，默认 true）
LOG_FILE_OUTPUT=true
YUNXI_LOG_FILE=true

# ---- 日志轮转配置 ----
# 是否启用轮转（默认 true）
LOG_ROTATION_ENABLED=true
YUNXI_LOG_ROTATION_ENABLED=true

# 轮转时机（midnight / hourly / daily / weekly，默认 midnight）
LOG_ROTATION_WHEN=midnight
YUNXI_LOG_ROTATION_WHEN=midnight

# 保留天数/份数（默认 30）
LOG_ROTATION_BACKUP_COUNT=30
YUNXI_LOG_ROTATION_BACKUP_COUNT=30

# 单文件最大字节数（兜底，默认 100MB）
LOG_ROTATION_MAX_BYTES=104857600
YUNXI_LOG_ROTATION_MAX_BYTES=104857600

# 是否自动 gzip 压缩（默认 true）
LOG_ROTATION_COMPRESS=true
YUNXI_LOG_ROTATION_COMPRESS=true

# 轮转间隔（默认 1）
LOG_ROTATION_INTERVAL=1
YUNXI_LOG_ROTATION_INTERVAL=1

# ---- Redis 日志输出（可选） ----
# 是否输出到 Redis 通道（默认 false）
LOG_REDIS_OUTPUT=false
YUNXI_LOG_REDIS=false
