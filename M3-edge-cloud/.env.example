# ============================================================
# M3 - 端云协同内核 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# ---- 基础配置 ----
M3_PORT=8003
M3_HOST=0.0.0.0
M3_ENV=development
YUNXI_ENV=development
YUNXI_LOG_LEVEL=info

# ---- 安全配置 ----
M3_ADMIN_TOKEN=your-m3-admin-token-here
M3_ENCRYPTION_KEY=your-m3-encryption-key-at-least-32chars

# ---- 数据库 ----
M3_DATABASE_PATH=./data/m3.db

# ---- CORS ----
CORS_ORIGINS=*
