# ============================================================
# M3 - 端云协同内核 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# ---- 基础配置 ----
M3_PORT=8003
M3_HOST=0.0.0.0
M3_ENV=development
YUNXI_ENV=development
YUNXI_LOG_LEVEL=info

# ---- 安全配置 ----
M3_ADMIN_TOKEN=your-m3-admin-token-here
M3_ENCRYPTION_KEY=your-m3-encryption-key-at-least-32chars

# ---- M8 标准对接 Token ----
# M8 管理平台访问 /m8/* 接口所需的鉴权 Token
# 优先级：M3_M8_TOKEN > M8_TOKEN > M3_ADMIN_TOKEN（向后兼容）
M3_M8_TOKEN=your-m3-m8-token-here
# M8_TOKEN=alternative-m8-token

# ---- 数据库 ----
M3_DATABASE_PATH=./data/m3.db

# ---- CORS ----
CORS_ORIGINS=*
