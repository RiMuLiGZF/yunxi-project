# ============================================================
# M5 - 潮汐记忆 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# M5 潮汐记忆系统环境变量配置示例
# ⚠️ 复制为 .env 并填入实际值，切勿提交到版本控制

# === 基础配置 ===
M5_ENV=production
M5_LOG_LEVEL=info

# === 安全配置（务必修改默认值） ===
# 加密密钥（32字节，base64编码）
M5_ENCRYPTION_KEY=REPLACE_WITH_YOUR_256BIT_KEY_BASE64
# JWT密钥
M5_JWT_SECRET=REPLACE_WITH_YOUR_JWT_SECRET
# 管理员Token
M5_ADMIN_TOKEN=REPLACE_WITH_ADMIN_TOKEN

# === 向量数据库配置 ===
M5_EMBEDDING_API_KEY=REPLACE_WITH_YOUR_KEY
M5_EMBEDDING_BASE_URL=https://api.example.com/v1
M5_VECTOR_BACKEND=chroma

# === 存储配置 ===
M5_STORAGE_PATH=./data/memory

# === 审计配置 ===
M5_AUDIT_ENABLED=true
M5_AUDIT_LOG_PATH=./logs/m5-audit.log

# === GPU 加速配置 ===
# 是否启用 GPU 向量检索（需要 faiss-gpu 和 CUDA）
M5_USE_GPU=false
# GPU 设备 ID（多卡时指定）
M5_GPU_DEVICE_ID=0
# GPU 显存使用比例（0~1，防止 OOM）
M5_GPU_MEMORY_RATIO=0.7
