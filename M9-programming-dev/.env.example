# ============================================================
# M9 - 编程开发 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# M9 配置示例
# 复制为 .env 并修改配置

# 监听地址
M9_HOST=0.0.0.0

# 监听端口
M9_PORT=8009

# 运行环境
M9_ENV=development

# 调试模式
M9_DEBUG=false

# 日志级别
M9_LOG_LEVEL=info

# 管理Token（M8对接）
M9_ADMIN_TOKEN=yunxi-m9-admin-token-2026

# Base URL
M9_BASE_URL=http://localhost:8009

# VSCode命令
M9_VSCODE_CODE_COMMAND=code

# 默认工作空间
M9_VSCODE_DEFAULT_WORKSPACE=~/projects

# VSCode端口范围起始
M9_VSCODE_PORT_RANGE_START=8080

# 代码执行超时（秒）
M9_CODE_EXEC_TIMEOUT=30

# 代码执行最大内存（MB）
M9_CODE_EXEC_MAX_MEMORY=512

# 是否启用代码沙箱
M9_CODE_EXEC_SANDBOX=true

# 项目根目录
M9_PROJECTS_ROOT_DIR=~/yunxi-projects
