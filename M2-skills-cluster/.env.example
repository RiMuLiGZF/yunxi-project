# ============================================================
# M2 - 技能集群 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# ---- 基础配置 ----
M2_PORT=8002
M2_HOST=0.0.0.0
M2_ENV=development
YUNXI_ENV=development

# ---- 安全配置 ----
M2_ADMIN_TOKEN=your-m2-admin-token-here
M2_ENCRYPTION_KEY=your-m2-encryption-key
M2_JWT_SECRET=your-m2-jwt-secret-key

# ---- 配置文件 ----
M2_CONFIG_PATH=config.yaml

# ---- CORS ----
M2_CORS_ORIGINS=*
CORS_ORIGINS=*

# ---- 沙箱配置 ----
SANDBOX_MAX_MEMORY_MB=256
SANDBOX_MAX_CPU_SECONDS=10

# ---- LLM 配置 ----
M2_LLM_API_KEY=your-llm-api-key
M2_LLM_BASE_URL=http://localhost:11434/v1

# ---- 数据库（可选） ----
M2_DB_HOST=localhost
M2_DB_USER=m2_user
M2_DB_PASSWORD=your-m2-db-password

# ---- Redis（可选） ----
M2_REDIS_URL=redis://localhost:6379/0

# ---- A2A 联邦 ----
M1_A2A_BUS_ENDPOINT=http://localhost:8001/a2a/bus
M2_A2A_CALLBACK=http://localhost:8002/a2a/callback

# === ONNX Runtime GPU 加速配置 ===
# ONNX 模型存储目录
ONNX_MODELS_DIR=~/.yunxi/models/onnx
# 首选后端: auto(自动检测)/cpu/cuda/tensorrt
ONNX_PREFERRED_BACKEND=auto
# GPU 设备 ID（多卡时指定）
ONNX_GPU_DEVICE_ID=0
# GPU 显存限制 (GB)
ONNX_GPU_MEMORY_LIMIT_GB=4
# 是否自动加载注册的模型
ONNX_AUTO_LOAD=false
# 翻译技能是否启用 ONNX 本地模型
ONNX_TRANSLATE_ENABLED=false
# 翻译 ONNX 模型名称（需先注册到模型管理器）
ONNX_TRANSLATE_MODEL=
