# ============================================================
# M10 - 系统卫士 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# M10 系统卫士配置示例
# 复制为 .env 并修改配置

# 服务配置
M10_HOST=0.0.0.0
M10_PORT=8010
M10_ENV=development

# 采样配置
M10_SAMPLE_INTERVAL=5

# M8 对接
M10_ADMIN_TOKEN=yunxi-m10-admin-token-2026
M10_BASE_URL=http://localhost:8010

# 阈值配置
M10_CPU_WARNING=70
M10_CPU_CRITICAL=90
M10_MEM_WARNING=75
M10_MEM_CRITICAL=90
M10_DISK_WARNING=80
M10_DISK_CRITICAL=95

# 审计配置
M10_AUDIT_RETENTION=30
M10_AUDIT_PATH=./data/audit

# === GPU 监控配置 ===
# 是否启用真实 GPU 监控（需要 NVIDIA 显卡和 nvidia-ml-py）
M10_GPU_MONITOR_ENABLED=true
# GPU 轮询间隔（毫秒）
M10_GPU_POLLING_INTERVAL_MS=500
# 是否监控 GPU 进程
M10_GPU_MONITOR_PROCESSES=true
# GPU 显存告警阈值 (%)
M10_GPU_MEMORY_WARNING_PERCENT=80
# GPU 温度告警阈值 (°C)
M10_GPU_TEMP_WARNING_CELSIUS=85

# === 潮汐引擎配置 ===
# 是否启用潮汐引擎
M10_TIDE_ENABLED=true
# 潮汐调度轮询间隔（秒）
M10_TIDE_POLL_INTERVAL=2
# 潮汐主指标: gpu_memory / gpu_util / combined
M10_TIDE_PRIMARY_METRIC=gpu_memory
# 涨潮阈值（%）- 低于此值为涨潮
M10_TIDE_FLOOD_THRESHOLD=30
# 退潮阈值（%）- 高于此值为退潮
M10_TIDE_EBB_THRESHOLD=70
# 枯潮阈值（%）- 高于此值为枯潮
M10_TIDE_LOW_THRESHOLD=90
# 涨潮并发系数
M10_TIDE_FLOOD_MULTIPLIER=2.0
# 平潮并发系数
M10_TIDE_SLACK_MULTIPLIER=1.0
# 退潮并发系数
M10_TIDE_EBB_MULTIPLIER=0.5
# 枯潮并发系数
M10_TIDE_LOW_MULTIPLIER=0.2
# 滞回区间（%）- 防止频繁切换阶段
M10_TIDE_HYSTERESIS=5
# 阶段最小持续时间（秒）
M10_TIDE_MIN_PHASE_DURATION=120
# 是否启用潮汐预测
M10_TIDE_PREDICTION_ENABLED=true
# 预测窗口（分钟）
M10_TIDE_PREDICTION_WINDOW=30
