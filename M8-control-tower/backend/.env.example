# ============================================================
# M8 - 云汐管理塔 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# M8-backend 配置示例
# 复制为 .env 并修改配置

# 监听地址
M8_HOST=0.0.0.0

# 监听端口
M8_PORT=8000

# 运行环境
M8_ENV=development

# 调试模式
M8_DEBUG=false

# 日志级别
M8_LOG_LEVEL=info

# 管理Token
M8_ADMIN_TOKEN=yunxi-m8-admin-token-2026

# 管理员用户名
M8_ADMIN_USERNAME=admin

# 管理员密码
M8_ADMIN_PASSWORD=admin123456

# JWT密钥
M8_JWT_SECRET=yunxi-m8-jwt-secret-2026

# 数据库路径
M8_DATABASE_PATH=./data/m8.db

# CORS允许来源（逗号分隔）
M8_CORS_ORIGINS=*

# 前端静态文件路径
M8_FRONTEND_PATH=../../frontend

# === GPU 算力配置 ===
# M10 系统卫士 API 地址（GPU 监控数据来源）
M10_BASE_URL=http://localhost:8700
# M10 API 认证 Token
M10_API_TOKEN=
# 是否启用 GPU 算力管理
GPU_COMPUTE_ENABLED=true
# GPU 状态同步间隔（秒）
GPU_SYNC_INTERVAL=30
# 默认最大并发 GPU 任务数
GPU_MAX_CONCURRENT_TASKS=10
