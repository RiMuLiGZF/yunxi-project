# ============================================================
# M6 - 硬件外设 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# M6 配置示例
# 复制为 .env 并修改配置

# 监听地址
M6_HOST=0.0.0.0

# 监听端口
M6_PORT=8006

# 运行环境
M6_ENV=development

# 日志级别
M6_LOG_LEVEL=info

# 管理Token（M8对接）
M6_ADMIN_TOKEN=yunxi-m6-admin-token-2026

# Base URL
M6_BASE_URL=http://localhost:8006

# 模拟器模式（true=模拟硬件）
M6_SIMULATION_MODE=true

# 传感器数据保留天数
M6_DATA_RETENTION_DAYS=7

# 设备扫描间隔（秒）
M6_SCAN_INTERVAL=5
