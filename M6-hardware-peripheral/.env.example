# ============================================================
# M6 - 硬件外设 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# ----- 基础配置 -----

# 模块名称
M6_NAME=m6-hardware

# 监听地址
M6_HOST=0.0.0.0

# 监听端口
M6_PORT=8006

# 运行环境（development / production）
# - development：未配置 M6_ADMIN_TOKEN 时自动生成随机一次性 Token
# - production：必须配置 M6_ADMIN_TOKEN，否则启动失败
M6_ENV=development

# 管理Token（M8对接）
# 安全提示：
# - 生产环境必须显式配置强随机 Token，禁止使用默认值
# - 开发环境未配置时会自动生成随机一次性 Token
# - 生成强密钥命令：python -c "import secrets; print(secrets.token_urlsafe(32))"
M6_ADMIN_TOKEN=CHANGEME_M6_ADMIN_TOKEN_REPLACE_WITH_STRONG_KEY

# 模拟模式（true=模拟硬件，false=连接真实硬件）
M6_SIMULATION_MODE=true

# ----- 数据库配置 -----

# 数据库文件路径（默认：项目根目录 data/m6_sensors.db）
# M6_DATABASE_PATH=./data/m6_sensors.db

# ----- 数据采集配置 -----

# 传感器采集间隔（秒）
M6_COLLECTION_INTERVAL=5

# 传感器数据保留天数
M6_DATA_RETENTION_DAYS=30

# ----- SSE 配置 -----

# SSE 推送间隔（秒）
M6_SSE_INTERVAL=5

# SSE 心跳间隔（秒）
M6_SSE_HEARTBEAT_INTERVAL=30

# SSE 令牌有效期（秒）
M6_SSE_TOKEN_TTL=300

# SSE 最大连接数
M6_SSE_MAX_CONNECTIONS=100

# ----- 电量配置 -----

# 低电量告警阈值（%）
M6_BATTERY_LOW_THRESHOLD=20

# 基础电量消耗速率（每小时）
M6_BATTERY_DRAIN_BASE=0.1

# ----- 设备配置 -----

# 默认设备配置文件路径（YAML，为空则使用内置默认设备）
# M6_DEFAULT_DEVICES_PATH=./config/devices.yaml

# ----- CORS 配置 -----

# CORS 允许的来源（多个用逗号分隔，* 表示允许所有）
CORS_ORIGINS=*

# ----- 日志配置 -----

# 日志级别（debug / info / warning / error）
YUNXI_LOG_LEVEL=info

# 日志目录（默认 ./logs）
LOG_DIR=./logs
YUNXI_LOG_DIR=./logs

# 日志格式（json / text，生产环境默认 json，开发环境默认 text）
LOG_FORMAT=text
YUNXI_LOG_FORMAT=text

# 是否输出到文件（true / false，默认 true）
LOG_FILE_OUTPUT=true
YUNXI_LOG_FILE=true

# ----- 日志轮转配置 -----

# 是否启用轮转（默认 true）
LOG_ROTATION_ENABLED=true
YUNXI_LOG_ROTATION_ENABLED=true

# 轮转时机（midnight / hourly / daily / weekly，默认 midnight）
LOG_ROTATION_WHEN=midnight
YUNXI_LOG_ROTATION_WHEN=midnight

# 保留天数/份数（默认 30）
LOG_ROTATION_BACKUP_COUNT=30
YUNXI_LOG_ROTATION_BACKUP_COUNT=30

# 单文件最大字节数（兜底，默认 100MB）
LOG_ROTATION_MAX_BYTES=104857600
YUNXI_LOG_ROTATION_MAX_BYTES=104857600

# 是否自动 gzip 压缩（默认 true）
LOG_ROTATION_COMPRESS=true
YUNXI_LOG_ROTATION_COMPRESS=true

# 轮转间隔（默认 1）
LOG_ROTATION_INTERVAL=1
YUNXI_LOG_ROTATION_INTERVAL=1

# ----- Redis 日志输出（可选） -----

# 是否输出到 Redis 通道（默认 false）
LOG_REDIS_OUTPUT=false
YUNXI_LOG_REDIS=false
