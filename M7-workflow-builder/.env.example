# ============================================================
# M7 - 工作流构建器 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# M7 配置示例
# 复制为 .env 并修改配置

# 监听地址
M7_HOST=0.0.0.0

# 监听端口
M7_PORT=8007

# 运行环境
M7_ENV=development

# 日志级别
M7_LOG_LEVEL=info

# 管理Token（M8对接）
M7_ADMIN_TOKEN=yunxi-m7-admin-token-2026

# Base URL
M7_BASE_URL=http://localhost:8007

# 工作流数据文件路径
M7_DATA_PATH=~/.yunxi/m7_workflows.json

# 最大并发运行工作流数
M7_MAX_RUNNING_WORKFLOWS=10

# M2技能集群地址
M7_M2_BASE_URL=http://localhost:8002

# 是否启用M2技能积木
M7_ENABLE_M2_SKILLS=true
