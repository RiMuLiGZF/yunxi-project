# ============================================================
# M1 - 多Agent集群调度 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# ---- 基础配置 ----
M1_PORT=8001
M1_HOST=0.0.0.0
M1_NAME=m1-scheduler

# ---- 运行环境 ----
YUNXI_ENV=development
YUNXI_LOG_LEVEL=info

# ---- 安全配置 ----
M1_ADMIN_TOKEN=your-m1-admin-token-here
M1_ENCRYPTION_KEY=your-m1-encryption-key-at-least-32chars
M1_JWT_SECRET=your-m1-jwt-secret-key

# ---- 数据库 ----
M1_DATABASE_URL=sqlite:///./data/m1.db

# ---- 联邦调度 ----
FEDERATION_MASTER_KEY=your-federation-master-key
FEDERATION_ADMIN_KEY=your-federation-admin-key
FEDERATION_INTERNAL_SECRET=your-federation-internal-secret

# ---- LLM 配置 ----
LLM_PROVIDER=ollama
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_TIMEOUT=60

# ---- CORS ----
CORS_ORIGINS=*
