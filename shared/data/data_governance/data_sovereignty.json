{
  "version": "2.0.0",
  "updated_at": "2026-07-17",
  "description": "云汐系统数据主权清单 - 定义各模块的数据所有权边界、分类分级与保留策略",
  "principle": "谁产生、谁拥有、谁维护。跨模块数据交互通过 HTTP API / 消息队列进行，禁止跨库直连。",

  "classification_rules": {
    "table_categories": {
      "core_data": {
        "label": "核心数据",
        "description": "业务核心数据，丢失将导致严重业务中断",
        "examples": ["用户数据", "订单数据", "配置数据"]
      },
      "config_data": {
        "label": "配置数据",
        "description": "系统或模块配置数据，变更频率低但影响范围广",
        "examples": ["系统设置", "功能开关", "KV存储"]
      },
      "log_data": {
        "label": "日志数据",
        "description": "审计日志、操作日志、调用日志等记录性数据",
        "examples": ["审计日志", "调用日志", "操作记录"]
      },
      "cache_data": {
        "label": "缓存数据",
        "description": "临时缓存、性能优化数据，丢失可重建",
        "examples": ["缓存条目", "会话缓存", "计算结果缓存"]
      }
    },
    "sensitivity_levels": {
      "public": {
        "label": "公开",
        "level": 1,
        "description": "可公开访问的数据，无敏感信息",
        "encryption_required": false
      },
      "internal": {
        "label": "内部",
        "level": 2,
        "description": "仅限内部使用的数据，对外不可见",
        "encryption_required": false
      },
      "sensitive": {
        "label": "敏感",
        "level": 3,
        "description": "包含用户隐私或业务敏感信息的数据",
        "encryption_required": true,
        "examples": ["用户个人信息", "健康数据", "财务数据"]
      },
      "confidential": {
        "label": "机密",
        "level": 4,
        "description": "高度机密数据，仅限授权人员访问",
        "encryption_required": true,
        "examples": ["API密钥", "密码哈希", "安全策略", "审计详情"]
      }
    },
    "retention_policies": {
      "permanent": {
        "label": "永久保留",
        "description": "需永久保留的核心数据",
        "max_age_days": null
      },
      "long_term": {
        "label": "长期保留",
        "description": "保留3年以上的重要数据",
        "max_age_days": 1095
      },
      "medium_term": {
        "label": "中期保留",
        "description": "保留1年的常规数据",
        "max_age_days": 365
      },
      "short_term": {
        "label": "短期保留",
        "description": "保留30-90天的日志类数据",
        "max_age_days": 90
      },
      "temporary": {
        "label": "临时保留",
        "description": "缓存类临时数据，随用随清",
        "max_age_days": 7
      }
    }
  },

  "modules": {
    "M0": {
      "name": "主理人管控台",
      "database": "m0.db",
      "sovereign": true,
      "core_domains": [
        "主理人账号认证",
        "审计日志（管控操作）",
        "系统配置（KV存储）",
        "模块状态缓存",
        "紧急锁定机制"
      ],
      "tables": [
        "audit_logs",
        "token_blacklist",
        "login_failures",
        "emergency_lock",
        "module_status",
        "config_kv"
      ],
      "table_metadata": {
        "audit_logs": {
          "category": "log_data",
          "sensitivity": "confidential",
          "retention": "long_term",
          "description": "管控台操作审计日志"
        },
        "token_blacklist": {
          "category": "config_data",
          "sensitivity": "confidential",
          "retention": "medium_term",
          "description": "JWT Token 黑名单"
        },
        "login_failures": {
          "category": "log_data",
          "sensitivity": "sensitive",
          "retention": "short_term",
          "description": "登录失败记录"
        },
        "emergency_lock": {
          "category": "config_data",
          "sensitivity": "confidential",
          "retention": "permanent",
          "description": "紧急锁定配置"
        },
        "module_status": {
          "category": "cache_data",
          "sensitivity": "internal",
          "retention": "temporary",
          "description": "模块状态缓存"
        },
        "config_kv": {
          "category": "config_data",
          "sensitivity": "internal",
          "retention": "permanent",
          "description": "系统配置 KV 存储"
        }
      },
      "cross_module_apis": [
        "GET /api/backup/list - 备份列表查询（M0自有）",
        "POST /api/backup/database - 立即备份（M0自有）"
      ],
      "notes": "M0是管控入口，不拥有业务数据。所有业务数据归各业务模块所有。"
    },

