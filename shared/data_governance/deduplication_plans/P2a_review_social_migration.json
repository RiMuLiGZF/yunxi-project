  "field_mapping": {
    "general_notes": [
      "字段名M8与M4基本一致，无需重命名",
      "user_id: M8 INTEGER → M4 VARCHAR(128)，迁移时转换为字符串",
      "JSON字段: M8存储为字符串，迁移时解析为Python对象后通过SQLAlchemy写入",
      "DateTime字段: M8存储为字符串，迁移时解析为Python datetime对象",
      "Boolean字段: M8存储为INTEGER(0/1)，迁移时转换为bool"
    ],
    "type_conversions": {
      "user_id": "INTEGER → VARCHAR(128) (str()转换)",
      "JSON字段": "TEXT字符串 → JSON对象 (json.loads)",
      "DateTime字段": "字符串 → datetime对象 (strptime)",
      "Boolean字段": "INTEGER → bool (bool())"
    },
    "tables_with_biz_id": ["review_reviews", "review_diaries", "review_decisions", "review_biases"],
    "tables_with_composite_key": ["review_emotions", "social_contacts", "social_interactions", "social_reminders", "social_eq_lessons"]
  },

