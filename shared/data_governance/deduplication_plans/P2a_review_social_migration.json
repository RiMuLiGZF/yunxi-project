    "retry_strategy": "指数退避 (1s, 2s, 4s)",
    "checkpoint_support": true,
    "checkpoint_location": "data/migration_checkpoints/p2a_review_social_checkpoint.json",
    "idempotency": "业务ID/组合键去重",
    "dry_run_support": true
  },

