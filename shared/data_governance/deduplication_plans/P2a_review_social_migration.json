{
  "phase": "P2a",
  "title": "复盘总结+人际关系数据迁移 - M8 → M4",
  "version": "1.0",
  "status": "completed",
  "domain": "review + social",
  "source_module": "M8-control-tower",
  "target_module": "M4-scene-engine",

  "background": {
    "current_state": "复盘总结和人际关系数据存储在M8控制塔数据库中，M4场景引擎已有对应的表结构但仅有测试/种子数据",
    "target_state": "M4成为复盘总结和人际关系数据的权威拥有者，M8通过API获取M4数据",
    "reasoning": [
      "复盘总结和人际关系是场景引擎的核心功能模块",
      "M4定位为场景引擎，应持有业务数据以支持场景联动",
      "M8是控制塔，不应持有业务明细数据",
      "数据迁移后M8仅通过API访问M4数据，保持数据一致性"
    ]
  },

  "migration_scope": {
