  "field_mapping": {
    "general_notes": [
      "M7表结构比M8更丰富，M8缺少的字段使用合理默认值",
      "id: 两边均为 VARCHAR(64)/String(64)，直接映射",
      "user_id: M8 INTEGER → M7 String 类型转换，M7无独立user_id字段，workflow_definitions映射到created_by，workflow_runs映射到triggered_by前缀",
      "JSON字段: M8存储为字符串/JSON类型，迁移时解析为Python对象后通过SQLAlchemy写入",
      "DateTime字段: 多格式解析兼容",
      "icon字段: M8有icon字段，M7无对应字段，迁移时忽略"
    ],
    "workflow_definitions_mapping": {
      "id": "id (String(64), 直接映射)",
      "name": "name (String(200), 直接映射)",
      "description": "description (Text, 直接映射)",
      "category": "category (String(50), 直接映射)",
      "icon": "→ 忽略（M7无对应字段）",
      "blocks": "blocks (JSON, 直接映射)",
      "status": "status (String(20), 直接映射)",
      "created_at": "created_at (DateTime, 直接映射)",
      "updated_at": "updated_at (DateTime, 直接映射)",
      "user_id": "created_by (INTEGER→String转换)",
      "(M7新增) connections": "默认值: []",
      "(M7新增) variables": "默认值: []",
      "(M7新增) trigger": "默认值: {}",
      "(M7新增) run_count": "默认值: 0",
      "(M7新增) tags": "默认值: []"
    },
    "workflow_runs_mapping": {
      "id": "id (String(64), 直接映射)",
      "workflow_id": "workflow_id (String(64), 直接映射)",
      "workflow_name": "workflow_name (String(200), 直接映射)",
      "status": "status (String(20), 直接映射)",
      "inputs": "inputs (JSON, 直接映射)",
      "outputs": "outputs (JSON, 直接映射)",
      "error_message": "error (字段重命名, TEXT→Text)",
      "started_at": "started_at (DateTime, 直接映射)",
      "finished_at": "finished_at (DateTime, 直接映射)",
      "duration_ms": "duration_ms (Integer, 直接映射)",
      "user_id": "triggered_by (INTEGER→String, 前缀m8_user_)",
