      "(M7新增) triggered_by": "默认值: m8_migrated"
    },
    "type_conversions": {
      "user_id": "INTEGER → String (str()转换)",
      "JSON字段": "TEXT/JSON字符串 → JSON对象 (json.loads)",
      "DateTime字段": "字符串 → datetime对象 (多格式解析)",
      "error_message → error": "字段重命名"
    }
  },

