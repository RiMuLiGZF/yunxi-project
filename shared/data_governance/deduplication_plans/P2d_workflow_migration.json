  "m7_table_analysis": {
    "workflow_definitions": {
      "primary_key": "id (String(64))",
      "total_fields": 14,
      "m8_common_fields": 8,
      "m7_extra_fields": ["connections", "variables", "trigger", "run_count", "created_by", "tags"],
      "indexes": ["ix_wf_name_category (name, category)"],
      "note": "M7比M8多6个字段，均为工作流引擎核心功能所需，设置合理默认值即可"
    },
    "workflow_runs": {
      "primary_key": "id (String(64))",
      "total_fields": 11,
      "m8_common_fields": 9,
      "m7_extra_fields": ["steps", "triggered_by"],
      "indexes": ["ix_run_wfid_status (workflow_id, status)"],
      "note": "M7比M8多2个字段：steps(步骤详情)和triggered_by(触发方式)，error字段名不同"
    }
  },

  "risks": [
    {
      "risk": "M7无独立user_id字段，数据归属追溯",
      "level": "medium",
      "mitigation": "workflow_definitions的user_id映射到created_by，workflow_runs的user_id映射到triggered_by前缀m8_user_，保留可追溯性"
    },
    {
      "risk": "M8 icon字段在M7无对应字段，信息丢失",
      "level": "low",
      "mitigation": "icon为展示辅助字段，不影响核心功能，M7工作流有自己的图标体系（通过积木块类型体现）"
    },
    {
      "risk": "M8工作流blocks格式与M7可能不完全兼容",
      "level": "high",
      "mitigation": "迁移时仅做数据搬运，不做结构转换。后续如需使用需经过工作流格式转换层处理"
    },
    {
      "risk": "M7缺少的字段默认值是否合理",
      "level": "medium",
      "mitigation": "connections/variables默认空列表，trigger默认空对象，run_count默认0，均符合业务逻辑默认值"
    }
  ],

