          {"name": "additions", "type": "Integer", "description": "新增行数"},
          {"name": "deletions", "type": "Integer", "description": "删除行数"},
          {"name": "files_changed", "type": "Integer", "description": "变更文件数"},
          {"name": "committed_at", "type": "DateTime", "index": true, "description": "提交时间"},
          {"name": "user_id", "type": "String(128)", "index": true, "description": "所属用户ID"}
