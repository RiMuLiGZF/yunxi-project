{
  "phase": "P1b",
  "title": "工作开发数据迁移 - M8 → M9",
  "version": "1.0",
  "status": "completed",
  "domain": "work_dev",
  "completed_at": "2026-07-17",

  "background": {
    "current_state": "工作开发相关的4张表全部在M8控制塔中，M9开发者工坊仅有workspace_projects和dev_activities等基础表，缺少项目管理、任务管理、提交记录、代码用量等核心业务表",
    "target_state": "M9成为工作开发数据的权威拥有者，M8通过API获取开发工作数据，M9持有完整的项目-任务-提交-用量数据链路",
    "reasoning": [
      "工作开发属于开发者工坊的核心业务领域",
      "M9定位就是开发者工作平台，应持有开发相关的全部业务数据",
      "M8是控制塔，不应持有业务明细数据，仅保留聚合指标",
      "workspace_projects（工作区文件项目）与work_projects（开发项目）是两个不同领域，分别对应文件管理和项目管理"
    ]
  },

  "current_data_locations": {
