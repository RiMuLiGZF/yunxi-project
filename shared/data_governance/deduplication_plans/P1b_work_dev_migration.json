          {"name": "project_id", "type": "Integer", "index": true, "description": "关联项目ID"},
          {"name": "assignee", "type": "String(100)", "description": "负责人"},
          {"name": "due_date", "type": "String(20)", "description": "截止日期"},
          {"name": "user_id", "type": "String(128)", "index": true, "description": "所属用户ID"},
          {"name": "created_at", "type": "DateTime", "default": "now"},
          {"name": "updated_at", "type": "DateTime", "default": "now", "onupdate": "now"}
