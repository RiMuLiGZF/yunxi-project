        {
          "name": "vscode_sessions",
          "fields_count": 6,
          "notes": "VS Code会话表，与开发项目管理无直接关系"
        },
        {
          "name": "mcp_tools",
          "fields_count": 8,
          "notes": "MCP工具注册表，与开发项目管理无直接关系"
        }
      ],
      "note": "M9没有与M8 work_*系列表直接对应的表，需要全部新增"
    }
  },

