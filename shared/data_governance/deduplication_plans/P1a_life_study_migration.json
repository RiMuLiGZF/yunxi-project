  "risks": [
    {
      "risk": "user_id 类型不匹配（M8 INTEGER vs M4 String）",
      "level": "high",
      "mitigation": "迁移时统一转换为字符串，对账时使用 str_compare 策略",
      "status": "resolved"
    },
    {
      "risk": "自增ID表的幂等性问题（直接插入id会冲突）",
      "level": "medium",
      "mitigation": "使用复合业务键做幂等检查，不向INSERT传入自增id字段",
      "status": "resolved"
    },
    {
      "risk": "M8部分表缺少created_at/updated_at字段",
      "level": "low",
      "mitigation": "迁移时使用 datetime.utcnow() 补默认值",
      "status": "resolved"
    },
    {
      "risk": "M4中已有预置数据（多用户测试数据）",
      "level": "low",
      "mitigation": "幂等检查基于user_id + 业务ID，不同用户数据互不影响",
      "status": "resolved"
    },
    {
      "risk": "会话事务回滚后状态异常",
      "level": "medium",
      "mitigation": "插入失败时自动 rollback 会话，保证后续操作正常",
      "status": "resolved"
    }
  ],

