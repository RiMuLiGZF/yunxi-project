        "每日数据对账",
        "不一致数据修复"
      ]
    },
    "step_3_switch_read": {
      "name": "切读阶段",
      "tasks": [
        "非关键路径读操作改调用目标模块 API",
        "核心路径读操作逐步切换",
        "M8 保留本地缓存（可选）",
        "持续监控错误率"
      ]
    },
    "step_4_cleanup": {
      "name": "停写清理阶段",
      "tasks": [
        "停止 M8 本地写操作",
        "目标模块成为唯一数据源",
        "7天观察期",
        "备份 M8 旧表",
        "删除 M8 业务表",
        "更新数据主权文档"
      ]
    }
  }
