# ============================================================
# M11 - MCP 总线服务 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# M11 配置示例
# 复制为 .env 并修改配置

# 监听地址
M11_HOST=0.0.0.0

# 监听端口
M11_PORT=8011

# 运行环境
M11_ENV=development

# 日志级别
M11_LOG_LEVEL=info

# 管理Token（M8对接）
# 安全提示：生产环境必须设置强密码，切勿使用默认值
M11_ADMIN_TOKEN=yunxi-m11-admin-token-2026

# 是否启用 API Key 鉴权（默认启用，设为 false 可在开发环境关闭）
M11_API_KEY_AUTH_ENABLED=true

# MCP 端点鉴权配置
# MCP_REQUIRE_AUTH: MCP 端点是否需要鉴权，默认启用
# MCP_DEFAULT_API_KEY: MCP 默认 API Key（开发环境有默认值，生产环境必须显式配置）
#   安全提示：生产环境必须修改为强密钥，切勿使用默认值
M11_MCP_REQUIRE_AUTH=true
M11_MCP_DEFAULT_API_KEY=your-strong-mcp-api-key-here

# CORS 允许的来源（逗号分隔，生产环境应配置具体域名）
M11_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# SQLite 数据库路径
M11_DB_PATH=~/.yunxi/m11_bus.db

# 心跳超时时间（秒）
M11_HEARTBEAT_TIMEOUT=30

# 工具刷新间隔（秒）
M11_TOOL_REFRESH_INTERVAL=300
