# ============================================================
# M11 - MCP 总线服务 环境变量配置示例
# 复制为 .env 后修改对应值
# ============================================================

# M11 配置示例
# 复制为 .env 并修改配置

# 监听地址
M11_HOST=0.0.0.0

# 监听端口
M11_PORT=8011

# 运行环境
M11_ENV=development

# 日志级别
M11_LOG_LEVEL=info

# 管理Token（M8对接）
# 安全提示：
# - 生产环境必须设置强随机 Token，切勿使用默认值
# - 开发环境未配置时会自动生成随机一次性 Token
# - 生成强密钥命令：python -c "import secrets; print(secrets.token_urlsafe(32))"
M11_ADMIN_TOKEN=CHANGEME_M11_ADMIN_TOKEN_REPLACE_WITH_STRONG_KEY

# 是否启用 API Key 鉴权（默认启用，设为 false 可在开发环境关闭）
M11_API_KEY_AUTH_ENABLED=true

# MCP 端点鉴权配置
# M11_MCP_REQUIRE_AUTH: MCP 端点是否需要鉴权，默认启用
# M11_MCP_DEFAULT_API_KEY: MCP 默认 API Key
#   安全提示：
#   - 生产环境必须显式配置强随机密钥
#   - 开发环境未配置时会自动生成随机一次性 Key
#   - 生成强密钥命令：python -c "import secrets; print(secrets.token_urlsafe(32))"
M11_MCP_REQUIRE_AUTH=true
M11_MCP_DEFAULT_API_KEY=CHANGEME_MCP_API_KEY_REPLACE_WITH_STRONG_KEY

# CORS 允许的来源（逗号分隔，生产环境应配置具体域名）
M11_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# SQLite 数据库路径
M11_DB_PATH=~/.yunxi/m11_bus.db

# 心跳超时时间（秒）
M11_HEARTBEAT_TIMEOUT=30

# 工具刷新间隔（秒）
M11_TOOL_REFRESH_INTERVAL=300
